# LianYu-PC 环境变量模板（复制为 .env，与 docker-compose.yml 一一对应）
# 使用: cp .env.example .env 后按注释填写，再 docker compose up -d --build
# 勿将 .env / secrets/platform-keys.txt 提交到 Git

# =============================================================================
# Docker Compose 中间件（必填，首次 up 会写入对应 volume）
# =============================================================================
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=lianyu
MYSQL_PASSWORD=change-me-mysql
MYSQL_PORT=3307

REDIS_PASSWORD=change-me-redis
REDIS_PORT=6379

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change-me-rabbit
RABBITMQ_PORT=5672

MINIO_ACCESS_KEY=change-me-minio
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=lianyu

MILVUS_PORT=19530

# =============================================================================
# 后端容器内连接（compose 会覆盖为服务名；本地非 Docker 跑后端时用 localhost）
# =============================================================================
MYSQL_HOST=localhost
REDIS_HOST=localhost
RABBITMQ_HOST=localhost
MINIO_ENDPOINT=http://localhost:9000
MILVUS_HOST=localhost

# =============================================================================
# 应用必填
# =============================================================================
# 团队 Jasypt 主密钥（必填，整行粘贴，通常较长）— 解密 api_key_vault 密文，不是 sk- API Key
# 向负责人索取，须与 V22 加密时一致；格式: v1=<Base64>,current=v1  详见 README「LIANYU_MASTER_KEY」
LIANYU_MASTER_KEY=

SERVER_PORT=8080
# LIANYU_FRONTEND_PORT=80  # legacy：compose 不再启动 frontend 容器
LIANYU_GATEWAY_HTTP_PORT=80
LIANYU_GATEWAY_HTTPS_PORT=443
LIANYU_GATEWAY_PORT=8088
APP_REVISION=dev

# =============================================================================
# 平台 AI（DeepSeek 等）— 仅使用 DB 10-key 池，不要填下面两项
# =============================================================================
# 留空！单 key / 逗号分隔 env 池已关闭，聊天走 api_key_vault DEFAULT 轮询
OPENAI_API_KEY=
OPENAI_API_KEYS=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=

# 团队 10-key 已由 Flyway V22 以密文写入 MySQL；仅轮换 key 时用 seed-default-vault-pool.ps1

# =============================================================================
# 可选能力
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=

# VL 视觉（qwen3-vl-plus 等），见 lianyu.ai.vision
DASHSCOPE_API_KEY=
# 记忆向量 text-embedding-v3（lianyu.ai.embedding）
EMBEDDING_API_KEY=
# 记忆重排序 gte-rerank-v2；留空则回退为 EMBEDDING_API_KEY
RERANKER_API_KEY=
LIANYU_VISION_MODEL=
LIANYU_MOMENTS_IMAGE_BASE_URL=
LIANYU_MOMENTS_IMAGE_API_KEY=

LIANYU_PUSH_ENABLED=false
LIANYU_PUSH_VAPID_PUBLIC_KEY=
LIANYU_PUSH_VAPID_PRIVATE_KEY=
LIANYU_PUSH_VAPID_SUBJECT=

LIANYU_API_DOCS_ENABLED=true
LIANYU_AI_DIRECT_CHAT=false

# Electron 打包：API 在 frontend/.env.production.cloud（不入库）；pepper 仅本地 .env
# 生成: openssl rand -hex 32
LIANYU_RUNTIME_SECRETS_PEPPER=

# =============================================================================
# 前端 / Electron（Vite 读取，变量名必须以 VITE_ 开头）
# =============================================================================
VITE_LIANYU_API_ORIGIN=http://localhost:8080
# VITE_LIANYU_CERT_FINGERPRINT=

# =============================================================================
# CORS（api-gateway nginx + Spring；逗号分隔，与 Electron VITE_LIANYU_API_ORIGIN 一致）
# 本地 Docker + Vite 开发示例:
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://localhost
# 云端生产示例（迁机后改 IP 并重打 Electron）:
# CORS_ALLOWED_ORIGINS=https://154.219.111.30,http://localhost:5173,https://localhost
