# LianYu-PC .gitignore（.env、密钥、构建产物不入库）
# =====================

# Environment
.env
secrets/platform-keys.txt
backend/scripts/_vault_reseed.sql
backend/scripts/out/

# Java / Maven
backend/target/
backend/*/target/
*.class
*.jar
*.war

# IDE / editor
.idea/
*.iml
.vscode/
.cursor/
*.tmp
.tmp_*
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Pet voice enrollment samples (keep clip + registry only)
backend/lianyu-service/src/main/resources/pet-voice-samples/*.wav
!backend/lianyu-service/src/main/resources/pet-voice-samples/*-clip.wav

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/dist-electron/
frontend/release/

# Docker
docker-compose.override.yml

# Local tooling / chat history (may contain secrets)
.specstory/
.codegraph/
.superpowers/
.worktrees/

# Deployment artifacts (large binaries)
.deploy-export/
