# LianYu-PC .gitignore（.env、密钥、构建产物不入库）
# =====================

# Environment
.env
secrets/platform-keys.txt
backend/scripts/_vault_reseed.sql
backend/scripts/out/

# Java / Maven
backend/target/
backend/*/target/
*.class
*.jar
*.war

# IDE / editor
.idea/
*.iml
.vscode/
.cursor/
*.tmp
.tmp_*
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Pet voice enrollment samples (keep clip + registry only)
backend/lianyu-service/src/main/resources/pet-voice-samples/*.wav
!backend/lianyu-service/src/main/resources/pet-voice-samples/*-clip.wav

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/dist-electron/
frontend/release/

# Docker
docker-compose.override.yml
certs/*.crt
certs/*.key


# Local tooling / chat history (may contain secrets)
.specstory/
.codegraph/
.cortexloop/
.superpowers/
.worktrees/
config.json
avatar/

# CodeCortexLoop generated reports (keep out of git)
docs/cortexloop/

# Deployment artifacts (large binaries)
.deploy-export/

# Installer red-team unpack output (regenerated by scripts/_audit_installer_unpack.py)
release_audit/

# Build artifacts (regenerated; not source)
frontend/main-bundle.cjs

# Local debug dumps
.issue_dump.json
.issue_dump.md
debug-*.png
frontend/build-agent-log.txt

# Release builds (regenerated by electron-builder)
frontend/release/
frontend/release-*/
# Installer skin artifacts (regenerated, large binaries)
frontend/build/skin/
frontend/build/nsNiuniuSkin.dll
frontend/build/x86-unicode/
frontend/build/*.bmp
frontend/build/logo.ico
frontend/build/skin.zip
# Generated scripts (one-off, not source)
frontend/scripts/gen-*.mjs
frontend/scripts/gen-*.cjs

# Python cache
**/__pycache__/
*.pyc
